{
  "manifest_version": 2,
  "name": "Twitch Auto Claim",
  "version": "1.2",
  "description": "Auto claims Twitch channel points.",
  "permissions": [
    "storage",
    "https://www.twitch.tv/*"
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "96": "icon96.png",
    "128": "icon128.png"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.twitch.tv/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "pointhunter@extension.com",
      "data_collection_permissions": {
        "privacy_policy": null,
        "required": ["none"]
      }
    }
  }
}